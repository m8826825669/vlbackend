# ──────────────────────────────────────────────────────────────────────────
# Vexen Labs backend — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────

# ─── Django core ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.vexenlabs.com

# ─── Database ─────────────────────────────────────────────────────────────
# Leave blank to use the default SQLite db.sqlite3 (dev only).
# Production examples:
#   PostgreSQL: postgres://user:password@host:5432/dbname
#   MySQL:      mysql://user:password@host:3306/dbname
DATABASE_URL=

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Include both http and https.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://vexenlabs.com,https://www.vexenlabs.com

# ─── Razorpay ─────────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys in development, rzp_live_* in production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX

# ─── Email ────────────────────────────────────────────────────────────────
# In dev, the default console backend prints emails to stdout — no SMTP needed.
# For real emails, uncomment the SMTP backend and fill in credentials.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=app-specific-password-not-your-real-password
DEFAULT_FROM_EMAIL=Vexen Labs <noreply@vexenlabs.com>

# ─── Redis / cache ────────────────────────────────────────────────────────
# Optional. If Redis isn't running, comment out the CACHES block in settings.py
# or set USE_DUMMY_CACHE=True (see settings).
REDIS_URL=redis://127.0.0.1:6379/1

# ─── Site identity ────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
SITE_NAME=Vexen Labs
SUPPORT_EMAIL=support@vexenlabs.com
CONTACT_PHONE=+91 91295 82882

# ─── Optional: S3-compatible file storage (AWS / DigitalOcean Spaces) ─────
# Leave commented out to use local file storage in MEDIA_ROOT.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=ap-south-1